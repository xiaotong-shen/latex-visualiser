{
  "name": "latex-visualiser",
  "displayName": "LaTeX Visualiser",
  "description": "Hover over equations in your LaTeX PDF to see interactive 3D visualizations powered by Plotly",
  "version": "0.1.0",
  "publisher": "latex-visualiser",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Visualization",
    "Education"
  ],
  "activationEvents": [
    "onLanguage:latex",
    "onLanguage:tex"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "latexVisualiser.openViewer",
        "title": "LaTeX Visualiser: Open PDF Viewer"
      },
      {
        "command": "latexVisualiser.generateProofImage",
        "title": "Generate Proof Image"
      },
      {
        "command": "latexVisualiser.refreshViz",
        "title": "LaTeX Visualiser: Refresh Visualizations"
      },
      {
        "command": "latexVisualiser.suggestVizAI",
        "title": "LaTeX Visualiser: Suggest Visualization (AI)"
      },
      {
        "command": "latexVisualiser.suggestOverlayAI",
        "title": "LaTeX Visualiser: Suggest Overlay Layer (AI)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "when": "resourceLangId == latex || resourceLangId == tex || resourceExtname == .tex",
          "command": "latexVisualiser.openViewer",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "latexVisualiser.generateProofImage",
          "when": "editorHasSelection && resourceExtname == .tex",
          "group": "1_modification"
        }
      ]
    },
    "configuration": {
      "title": "LaTeX Visualiser",
      "properties": {
        "latexVisualiser.anthropicApiKey": {
          "type": "string",
          "default": "",
          "description": "Anthropic API key for Claude-powered proof diagram generation"
        },
        "latexVisualiser.pdfPath": {
          "type": "string",
          "default": "",
          "description": "Path to the compiled PDF file (auto-detected if empty)"
        },
        "latexVisualiser.plotResolution": {
          "type": "number",
          "default": 50,
          "description": "Resolution of 3D surface plots (grid points per axis)"
        },
        "latexVisualiser.popupWidth": {
          "type": "number",
          "default": 450,
          "description": "Width of the visualization popup in pixels"
        },
        "latexVisualiser.popupHeight": {
          "type": "number",
          "default": 400,
          "description": "Height of the visualization popup in pixels"
        },
        "latexVisualiser.aiProvider": {
          "type": "string",
          "enum": [
            "openaiCompatible"
          ],
          "default": "openaiCompatible",
          "description": "AI suggestion provider. This extension is configured to always use OpenAI-compatible chat completions."
        },
        "latexVisualiser.aiBaseUrl": {
          "type": "string",
          "default": "https://api.openai.com/v1",
          "description": "Base URL for the OpenAI-compatible API provider."
        },
        "latexVisualiser.aiModel": {
          "type": "string",
          "default": "gpt-4.1-mini",
          "description": "OpenAI model id used for chat completions."
        },
        "latexVisualiser.aiApiKey": {
          "type": "string",
          "default": "",
          "description": "OpenAI-compatible API key override (falls back to OPENAI_API_KEY, then 'test')."
        },
        "latexVisualiser.aiTimeoutMs": {
          "type": "number",
          "default": 8000,
          "description": "Request timeout in milliseconds for AI provider calls."
        },
        "latexVisualiser.aiDebugLogs": {
          "type": "boolean",
          "default": false,
          "description": "Enable verbose AI logs (prompt, provider, model, raw response) in the 'LaTeX Visualiser AI' output channel."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "dotenv": "^17.3.1",
    "pdfjs-dist": "^5.5.207",
    "plotly.js-dist-min": "^3.4.0"
  }
}
